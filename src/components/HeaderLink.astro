---
import type { HTMLAttributes } from 'astro/types';
import { locales } from '../i18n/ui';

type Props = HTMLAttributes<'a'>;

const { href = '/', class: className, ...props } = Astro.props;
const normalizePath = (value: string | URL | null | undefined) => {
	const raw = String(value ?? '/');
	const base = import.meta.env.BASE_URL;
	const normalized = base !== '/' && raw.startsWith(base) ? raw.slice(base.length - 1) : raw;
	const cleaned = normalized.replace(/\/+$/, '');
	return cleaned === '' ? '/' : cleaned;
};
const pathname = normalizePath(Astro.url.pathname);
const targetPath = normalizePath(href);
const targetSegments = targetPath.split('/').filter(Boolean);
const isLocalizedHome = targetSegments.length === 1 && locales.includes(targetSegments[0] as (typeof locales)[number]);
const supportsPrefixMatch = targetPath !== '/' && !isLocalizedHome;
const isActive = pathname === targetPath || (supportsPrefixMatch && pathname.startsWith(`${targetPath}/`));
---

<a href={href} class:list={[className, { active: isActive }]} {...props}>
	<slot />
</a>
<style>
	a {
		display: inline-flex;
		align-items: center;
		padding: 0.45rem 0.8rem;
		border-radius: 999px;
		text-decoration: none;
		font-weight: 600;
		color: var(--nav-link);
		transition: background-color 180ms ease, color 180ms ease;
	}
	a:hover {
		background: var(--nav-link-hover-bg);
		color: var(--nav-link-hover-text);
	}
	a.active {
		color: var(--nav-active-text);
		background: var(--signal);
	}
</style>
