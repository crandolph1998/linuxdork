---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { getLocaleFromPathname } from '../i18n/ui';

type Props = CollectionEntry<'blog'>['data'];

const locale = getLocaleFromPathname(Astro.url.pathname);
const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang={locale}>
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: min(1080px, calc(100% - 2rem));
				max-width: 100%;
				margin: 0 auto;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				width: 100%;
				height: auto;
				border-radius: 1rem;
				border: 1px solid var(--hero-recent-border);
			}
			.prose {
				width: 100%;
				max-width: 100%;
				margin: auto;
				padding: 1.3rem;
				color: color-mix(in srgb, var(--foreground) 92%, var(--muted) 8%);
				background: var(--surface-gradient);
				border-radius: 1rem;
				border: 1px solid var(--hero-recent-border);
				margin-top: 0.9rem;
			}
			.title {
				margin-bottom: 1em;
				padding: 0.3rem 0 0.7rem;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: var(--date-muted);
			}
			.last-updated-on {
				font-style: italic;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
