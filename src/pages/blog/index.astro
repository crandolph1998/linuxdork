---
import { Image } from 'astro:assets';
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import { getLocaleFromPathname, getTranslations, withLocale } from '../../i18n/ui';

const locale = getLocaleFromPathname(Astro.url.pathname);
const t = getTranslations(locale);

const allPosts = await getCollection('blog');
const posts = allPosts
	.filter((p: CollectionEntry<'blog'>) => !p.id.includes('/'))
	.sort(
		(a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) =>
			b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
	);
// Build a map of translated metadata for the current locale
const translatedMap = new Map(
	allPosts
		.filter((p: CollectionEntry<'blog'>) => p.id.startsWith(`${locale}/`))
		.map((p: CollectionEntry<'blog'>) => [p.id.replace(`${locale}/`, ''), p.data]),
);
---

<!doctype html>
<html lang={locale}>
	<head>
		<BaseHead title={t.blog.metaTitle || SITE_TITLE} description={t.blog.metaDescription} />
		<style>
			main {
				width: min(1080px, calc(100% - 2rem));
			}
			ul {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 1rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: 100%;
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				grid-column: span 2;
			}
			ul li:first-child img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 2.1rem;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 0.9rem;
				border: 1px solid var(--hero-recent-border);
			}
			ul li a {
				display: block;
				padding: 0.9rem;
				border-radius: 1rem;
				background: var(--surface-gradient);
				border: 1px solid var(--hero-recent-border);
			}
			.title {
				margin: 0;
				color: var(--title-strong);
				line-height: 1;
			}
			.date {
				margin: 0.45rem 0 0;
				color: var(--date-muted);
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: var(--link-hover);
			}
			ul a:hover img {
				box-shadow: 0 0 0 1px var(--image-outline);
			}
			ul li a:hover {
				transform: translateY(-2px);
				border-color: var(--hero-recent-hover-border);
			}
			@media (max-width: 720px) {
				ul {
					grid-template-columns: 1fr;
					gap: 0.7rem;
				}
				ul li {
					width: 100%;
				}
				ul li:first-child {
					grid-column: span 1;
				}
				ul li:first-child .title {
					font-size: 1.5rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<ul>
					{
						posts.map((post) => {
							const tData = translatedMap.get(post.id);
							return (
								<li>
									<a href={withLocale(locale, `/blog/${post.id}`)}>
										{post.data.heroImage && (
											<Image width={720} height={360} src={post.data.heroImage} alt="" />
										)}
										<h4 class="title">{tData?.title ?? post.data.title}</h4>
										<p class="date">
											<FormattedDate date={post.data.pubDate} />
										</p>
									</a>
								</li>
							);
						})
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
