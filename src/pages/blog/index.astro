---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate } from '../../utils/format-date';

const posts = (await getCollection('blog')).sort((a, b) =>
  b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Blog" description="Linux Dork blog posts about Linux, shell scripting, and open-source tooling.">
  <h1>Linux Dork Blog</h1>
  <p class="muted">Tutorials, troubleshooting notes, and terminal workflows.</p>

  {posts.map((post) => (
    <article class="card">
      <h2><a href={`/blog/${post.id}/`}>{post.data.title}</a></h2>
      <p class="muted">
        Published {formatDate(post.data.pubDate)}
        {post.data.updatedDate && ` • Updated ${formatDate(post.data.updatedDate)}`}
      </p>
      <p>{post.data.description}</p>
      {post.data.tags.length > 0 && (
        <p class="muted">Tags: {post.data.tags.join(' • ')}</p>
      )}
    </article>
  ))}
</BaseLayout>
