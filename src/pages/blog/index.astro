---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import { getLocaleFromPathname, getTranslations, withLocale } from '../../i18n/ui';

const locale = getLocaleFromPathname(Astro.url.pathname);
const t = getTranslations(locale);

const allPosts = await getCollection('blog');
const posts = allPosts
	.filter((p: CollectionEntry<'blog'>) => !p.id.includes('/'))
	.sort(
		(a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) =>
			b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
	);
// Build a map of translated metadata for the current locale
const translatedMap = new Map(
	allPosts
		.filter((p: CollectionEntry<'blog'>) => p.id.startsWith(`${locale}/`))
		.map((p: CollectionEntry<'blog'>) => [p.id.replace(`${locale}/`, ''), p.data]),
);
---

<!doctype html>
<html lang={locale}>
	<head>
		<BaseHead title={t.blog.metaTitle || SITE_TITLE} description={t.blog.metaDescription} />
		<style>
			main {
				width: min(1080px, calc(100% - 2rem));
			}
			.hero {
				padding: clamp(1.2rem, 4vw, 2.2rem);
			}
			.lead {
				max-width: 65ch;
			}
			ul {
				display: grid;
				grid-template-columns: 1fr;
				gap: 0.9rem;
				list-style-type: none;
				margin: 1rem 0 0;
				padding: 0;
			}
			ul li {
				width: 100%;
			}
			.post-card {
				display: block;
				padding: 1rem 1.1rem;
				border-radius: 1rem;
				background: var(--surface-gradient);
				border: 1px solid var(--hero-recent-border);
				text-decoration: none;
				transition: transform 0.2s ease, border-color 0.2s ease;
			}
			.title {
				margin: 0;
				color: var(--title-strong);
				line-height: 1.1;
				font-size: 1.3rem;
			}
			.date {
				margin: 0.45rem 0;
				color: var(--date-muted);
			}
			.excerpt {
				margin: 0;
				color: color-mix(in srgb, var(--foreground) 88%, var(--muted) 12%);
			}
			.post-card:hover .title,
			.post-card:hover .date {
				color: var(--link-hover);
			}
			.post-card:hover {
				transform: translateY(-2px);
				border-color: var(--hero-recent-hover-border);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="surface-card hero scan-lines">
				<div class="terminal-pill">grep -R "linux" notes/</div>
				<h1>{t.header.blog}</h1>
				<p class="lead">{t.blog.metaDescription}</p>
			</section>

			<section>
				<ul>
					{
						posts.map((post) => {
							const tData = translatedMap.get(post.id);
							return (
								<li>
									<a class="post-card" href={withLocale(locale, `/blog/${post.id}`)}>
										<h4 class="title">{tData?.title ?? post.data.title}</h4>
										<p class="date">
											<FormattedDate date={post.data.pubDate} />
										</p>
										<p class="excerpt">{tData?.description ?? post.data.description}</p>
									</a>
								</li>
							);
						})
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
