---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { Button } from '@/components/ui/button';
import { SITE_TITLE } from '../consts';
import { getLocaleFromPathname, getTranslations, withLocale } from '../i18n/ui';

const locale = getLocaleFromPathname(Astro.url.pathname);
const t = getTranslations(locale);

const posts = (await getCollection('blog'))
	.sort(
		(a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) =>
			b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
	)
	.slice(0, 3);
---

<!doctype html>
<html lang={locale}>
	<head>
		<BaseHead title={SITE_TITLE} description={t.siteDescription} />
	</head>
	<body>
		<Header />
		<main>
			<section class="surface-card hero scan-lines">
				<div class="terminal-pill">uname -a</div>
				<h1>Linux Dork</h1>
				<p class="lead">{t.home.lead}</p>
				<div class="cta-row">
					<Button asChild>
						<a href={withLocale(locale, '/blog')}>{t.home.archiveCta}</a>
					</Button>
					<Button variant="secondary" asChild>
						<a href={withLocale(locale, '/about')}>{t.home.aboutCta}</a>
					</Button>
				</div>
			</section>

			<section class="stats">
				{
					t.home.stats.map((item) => (
						<div class="surface-card stat">
							<h3>{item.title}</h3>
							<p>{item.body}</p>
						</div>
					))
				}
			</section>

			<section class="surface-card recent">
				<h2>{t.home.recentTitle}</h2>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={withLocale(locale, `/blog/${post.id}`)}>
									<h3>{post.data.title}</h3>
									<p>{post.data.description}</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		padding: clamp(1.2rem, 4vw, 2.2rem);
	}
	.lead {
		max-width: 65ch;
		font-size: clamp(1rem, 2.5vw, 1.2rem);
	}
	.cta-row {
		display: flex;
		gap: 0.8rem;
		flex-wrap: wrap;
		margin-top: 1rem;
	}
	.stats {
		display: grid;
		gap: 0.85rem;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		margin-top: 1rem;
	}
	.stat {
		padding: 1rem;
	}
	.stat h3 {
		margin-bottom: 0.4rem;
		font-size: 1.12rem;
	}
	.recent {
		margin-top: 1rem;
		padding: 1.2rem;
	}
	.recent ul {
		list-style: none;
		margin: 0.8rem 0 0;
		padding: 0;
		display: grid;
		gap: 0.7rem;
	}
	.recent li a {
		display: block;
		padding: 0.9rem;
		border-radius: 0.8rem;
		text-decoration: none;
		border: 1px solid var(--hero-recent-border);
		background: var(--hero-recent-bg);
		transition: transform 190ms ease, border-color 190ms ease;
	}
	.recent li a:hover {
		transform: translateY(-2px);
		border-color: var(--hero-recent-hover-border);
	}
	.recent h3 {
		margin-bottom: 0.3rem;
		font-size: 1.15rem;
	}
	.recent p {
		margin: 0;
	}
	@media (max-width: 860px) {
		.stats {
			grid-template-columns: 1fr;
		}
	}
</style>
