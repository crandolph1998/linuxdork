const c = policyCopy[locale];
---

<!doctype html>
<html lang={locale}>
  <head>
    <BaseHead
      title={c.pageTitle}
      description={c.pageDescription}
    />
  </head>
  <body>
    <Header />
    <main>
      <section class="surface-card policy">
        <div class="terminal-pill">privacy</div>
        <h1>{c.heading}</h1>
        <p class="meta">{c.lastUpdated}: {updatedOn}</p>
        <p>{c.intro}</p>

        <h2>{c.collectTitle}</h2>
        <ul>
          {c.collectItems.map((item) => <li>{item}</li>)}
        </ul>

        <h2>{c.avoidTitle}</h2>
        <ul>
          {c.avoidItems.map((item) => <li>{item}</li>)}
        </ul>

        <h2>{c.newsletterTitle}</h2>
        <p>{c.newsletterBody}</p>

        <h2>{c.cookiesTitle}</h2>
        <p>{c.cookiesBody}</p>

        <h2>{c.contactTitle}</h2>
        <p>{c.contactBody}</p>

        <p class="back"><a href={withLocale(locale, '/')}>{c.backHome}</a></p>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .policy {
    padding: clamp(1.1rem, 3.2vw, 1.8rem);
  }

  .meta {
    color: var(--date-muted);
    margin-bottom: 1rem;
  }

  .policy h2 {
    margin-top: 1.2rem;
  }

  .policy ul {
    margin: 0.4rem 0 0.8rem;
    padding-left: 1.2rem;
  }

  .back {
    margin-top: 1.2rem;
  }
</style>
