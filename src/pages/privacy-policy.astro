    intro: string;
    lastUpdated: string;
    collectTitle: string;
    collectItems: string[];
    avoidTitle: string;
    avoidItems: string[];
    newsletterTitle: string;
    newsletterBody: string;
    cookiesTitle: string;
    cookiesBody: string;
    contactTitle: string;
    contactBody: string;
    backHome: string;
  }
