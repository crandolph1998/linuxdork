  nl: {
    pageTitle: 'Privacybeleid | Linux Dork',
    pageDescription: 'Eenvoudig privacybeleid van Linux Dork over analytics, nieuwsbrief en contact.',
    heading: 'Privacybeleid',
    intro:
      'Linux Dork is een content- en toolsite. Dit beleid houden we simpel: we verzamelen alleen wat nodig is om de site te laten werken, basisgebruik te begrijpen en optionele nieuwsbriefupdates te versturen.',
    lastUpdated: 'Laatst bijgewerkt',
    collectTitle: 'Wat we verzamelen',
    collectItems: [
      'Basis serverlogs (voor beveiliging en troubleshooting).',
      'Geaggregeerde analyticsgegevens (pageviews, populaire paginas, verkeersbronnen).',
      'E-mailadres alleen als je het nieuwsbriefformulier verstuurt.',
    ],
    avoidTitle: 'Wat we niet verzamelen',
    avoidItems: [
      'Geen gevoelige persoonsgegevens worden bewust opgevraagd.',
      'Geen verkoop van persoonsgegevens.',
      'Geen accountprofielen of gedragsfingerprinting by design.',
