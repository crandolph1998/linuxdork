const toolsPath = withLocale(locale, '/tools');
const toolPath = withLocale(locale, '/tools/chmod-chown-builder');

const faqJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: t.faq.map((entry) => ({
    '@type': 'Question',
    name: entry.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: entry.a,
    },
  })),
});
---

<!doctype html>
<html lang={locale}>
  <head>
    <BaseHead title={t.metaTitle} description={t.metaDescription} />
    <script type="application/ld+json" set:html={faqJsonLd}></script>
  </head>
  <body>
    <Header />
    <main>
      <section class="surface-card hero scan-lines">
        <div class="terminal-pill">chmod -R 755 /srv/app</div>
        <h1>{t.title}</h1>
        <p class="lead">{t.lead}</p>
        <a class="back-link" href={toolsPath}>{t.backToTools}</a>
      </section>

      <section
        class="tool-grid"
        id="chmod-tool"
        data-copy-label={t.copy}
        data-copied-label={t.copied}
        data-invalid-mode-label={t.invalidMode}
        data-no-chown-label={t.noChown}
      >
        <article class="surface-card builder">
          <div class="field-row">
            <label for="target-path">{t.filePath}</label>
            <input id="target-path" type="text" value="/var/www/html" spellcheck="false" />
          </div>

          <div class="toggle-row">
            <label><input id="recursive" type="checkbox" /> {t.recursive}</label>
            <span class="hint">{t.ownerGroupHint}</span>
          </div>

          <h2>{t.modeBuilder}</h2>
          <div class="matrix">
            <div class="matrix-head"></div>
            <div class="matrix-head">{t.read}</div>
            <div class="matrix-head">{t.write}</div>
            <div class="matrix-head">{t.execute}</div>

            <div class="matrix-row-label">{t.user}</div>
            <input data-role="u" data-bit="r" type="checkbox" checked />
            <input data-role="u" data-bit="w" type="checkbox" checked />
            <input data-role="u" data-bit="x" type="checkbox" checked />

            <div class="matrix-row-label">{t.groupLabel}</div>
            <input data-role="g" data-bit="r" type="checkbox" checked />
            <input data-role="g" data-bit="w" type="checkbox" />
            <input data-role="g" data-bit="x" type="checkbox" checked />

            <div class="matrix-row-label">{t.other}</div>
            <input data-role="o" data-bit="r" type="checkbox" checked />
            <input data-role="o" data-bit="w" type="checkbox" />
            <input data-role="o" data-bit="x" type="checkbox" checked />
          </div>

          <div class="special-row">
            <span>{t.specialBits}</span>
            <label><input data-special="suid" type="checkbox" /> {t.suid}</label>
            <label><input data-special="sgid" type="checkbox" /> {t.sgid}</label>
            <label><input data-special="sticky" type="checkbox" /> {t.sticky}</label>
          </div>

          <div class="preset-row" aria-label={t.presets}>
            <button type="button" data-preset="755">755</button>
            <button type="button" data-preset="644">644</button>
            <button type="button" data-preset="700">700</button>
            <button type="button" data-preset="775">775</button>
            <button type="button" data-preset="600">600</button>
          </div>

          <div class="output-grid">
            <div>
              <div class="section-label">{t.modeOctal}</div>
              <p id="mode-octal" class="result">755</p>
            </div>
            <div>
              <div class="section-label">{t.modeSymbolic}</div>
              <p id="mode-symbolic" class="result">u=rwx,g=rx,o=rx</p>
            </div>
          </div>

          <div class="owner-grid">
            <div class="field-row">
              <label for="owner-input">{t.owner}</label>
              <input id="owner-input" type="text" value="www-data" spellcheck="false" />
            </div>
            <div class="field-row">
              <label for="group-input">{t.group}</label>
              <input id="group-input" type="text" value="www-data" spellcheck="false" />
            </div>
          </div>

          <div class="command-block">
            <div class="section-label">{t.chmodPreview}</div>
            <pre><code id="chmod-command">chmod 755 /var/www/html</code></pre>
            <button id="copy-chmod" type="button">{t.copy}</button>
          </div>

          <div class="command-block">
            <div class="section-label">{t.chownPreview}</div>
            <pre><code id="chown-command">chown www-data:www-data /var/www/html</code></pre>
            <button id="copy-chown" type="button">{t.copy}</button>
          </div>

          <p id="tool-error" class="error-message" hidden></p>
        </article>

        <article class="surface-card seo-copy">
          <h2>{t.seoTitle}</h2>
          <p>{t.seoBody}</p>
        </article>
      </section>

      <section class="surface-card faq-copy" aria-label={t.faqTitle}>
        <h2>{t.faqTitle}</h2>
        {
          t.faq.map((entry) => (
            <article>
              <h3>{entry.q}</h3>
              <p>{entry.a}</p>
            </article>
          ))
        }
      </section>
    </main>
    <Footer />

    <script is:inline define:vars={{ toolPath }}>
      const tool = document.getElementById('chmod-tool');
      const pathInput = document.getElementById('target-path');
      const recursiveInput = document.getElementById('recursive');
      const ownerInput = document.getElementById('owner-input');
      const groupInput = document.getElementById('group-input');
      const permBoxes = Array.from(document.querySelectorAll('input[data-role]'));
      const specialBoxes = Array.from(document.querySelectorAll('input[data-special]'));
      const modeOctal = document.getElementById('mode-octal');
      const modeSymbolic = document.getElementById('mode-symbolic');
      const chmodOutput = document.getElementById('chmod-command');
      const chownOutput = document.getElementById('chown-command');
      const errorOutput = document.getElementById('tool-error');
      const copyChmod = document.getElementById('copy-chmod');
      const copyChown = document.getElementById('copy-chown');
      const presetButtons = Array.from(document.querySelectorAll('button[data-preset]'));

      const copyLabel = tool?.dataset.copyLabel || 'Copy';
      const copiedLabel = tool?.dataset.copiedLabel || 'Copied';
      const noChownLabel = tool?.dataset.noChownLabel || 'No chown command generated yet.';

      function shellQuote(value) {
        if (!value) return "''";
        return `'${value.replace(/'/g, `'\\''`)}'`;
      }

      function roleBits(role) {
        const read = document.querySelector(`input[data-role="${role}"][data-bit="r"]`)?.checked;
        const write = document.querySelector(`input[data-role="${role}"][data-bit="w"]`)?.checked;
        const exec = document.querySelector(`input[data-role="${role}"][data-bit="x"]`)?.checked;
        const value = (read ? 4 : 0) + (write ? 2 : 0) + (exec ? 1 : 0);
        const symbolic = `${read ? 'r' : ''}${write ? 'w' : ''}${exec ? 'x' : ''}`;
        return { value, symbolic };
      }

      function getSpecialDigit() {
        const suid = document.querySelector('input[data-special="suid"]')?.checked ? 4 : 0;
        const sgid = document.querySelector('input[data-special="sgid"]')?.checked ? 2 : 0;
        const sticky = document.querySelector('input[data-special="sticky"]')?.checked ? 1 : 0;
        return suid + sgid + sticky;
      }

      function applyPreset(mode) {
        const normalized = mode.padStart(4, '0');
        const digits = normalized.split('').map((d) => Number(d));
        const special = digits[0];
        const perms = digits.slice(1);

        const [u, g, o] = perms;
        const mapping = [
          { role: 'u', value: u },
          { role: 'g', value: g },
          { role: 'o', value: o },
        ];

        mapping.forEach(({ role, value }) => {
          const read = (value & 4) !== 0;
          const write = (value & 2) !== 0;
          const exec = (value & 1) !== 0;
          const r = document.querySelector(`input[data-role="${role}"][data-bit="r"]`);
          const w = document.querySelector(`input[data-role="${role}"][data-bit="w"]`);
          const x = document.querySelector(`input[data-role="${role}"][data-bit="x"]`);
          if (r) r.checked = read;
          if (w) w.checked = write;
          if (x) x.checked = exec;
        });

        const suid = document.querySelector('input[data-special="suid"]');
        const sgid = document.querySelector('input[data-special="sgid"]');
        const sticky = document.querySelector('input[data-special="sticky"]');
        if (suid) suid.checked = (special & 4) !== 0;
        if (sgid) sgid.checked = (special & 2) !== 0;
        if (sticky) sticky.checked = (special & 1) !== 0;

        rebuild();
      }

      function rebuild() {
        const path = (pathInput?.value || '').trim() || '/path/to/target';
        const recursive = recursiveInput?.checked ? '-R ' : '';

        const user = roleBits('u');
        const group = roleBits('g');
        const other = roleBits('o');
        const special = getSpecialDigit();

        const octal = `${special > 0 ? special : ''}${user.value}${group.value}${other.value}`;
        const symbolic = `u=${user.symbolic},g=${group.symbolic},o=${other.symbolic}`;

        const chmod = `chmod ${recursive}${octal} ${shellQuote(path)}`;

        const owner = (ownerInput?.value || '').trim();
        const grp = (groupInput?.value || '').trim();

        let chown = noChownLabel;
        if (owner || grp) {
          const ownerPart = `${owner}${grp ? `:${grp}` : ''}`;
          const groupOnlyPart = !owner && grp ? `:${grp}` : ownerPart;
          chown = `chown ${recursive}${groupOnlyPart} ${shellQuote(path)}`;
        }

        if (modeOctal) modeOctal.textContent = octal;
        if (modeSymbolic) modeSymbolic.textContent = symbolic;
        if (chmodOutput) chmodOutput.textContent = chmod;
        if (chownOutput) chownOutput.textContent = chown;
        if (errorOutput) {
          errorOutput.hidden = true;
          errorOutput.textContent = '';
        }

        const url = new URL(window.location.href);
        url.searchParams.set('mode', octal);
        url.searchParams.set('path', path);
        history.replaceState({}, '', url.toString());
      }

      async function copyCommand(command, button) {
        if (!command || command === noChownLabel) return;
        await navigator.clipboard.writeText(command);
        if (!button) return;
        const original = button.textContent;
        button.textContent = copiedLabel;
        setTimeout(() => {
          button.textContent = original || copyLabel;
        }, 1200);
      }

      permBoxes.forEach((input) => input.addEventListener('change', rebuild));
      specialBoxes.forEach((input) => input.addEventListener('change', rebuild));
      pathInput?.addEventListener('input', rebuild);
      recursiveInput?.addEventListener('change', rebuild);
      ownerInput?.addEventListener('input', rebuild);
      groupInput?.addEventListener('input', rebuild);

      copyChmod?.addEventListener('click', () => copyCommand(chmodOutput?.textContent || '', copyChmod));
      copyChown?.addEventListener('click', () => copyCommand(chownOutput?.textContent || '', copyChown));

      presetButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const preset = btn.dataset.preset;
          if (preset) applyPreset(preset);
        });
      });

      rebuild();
    </script>
  </body>
</html>

