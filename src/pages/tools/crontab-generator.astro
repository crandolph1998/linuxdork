			'这个 Linux cron 计划生成器面向实际的服务器与 homelab 工作流。如果你需要一个快速的 crontab 表达式解析器，这个页面可以在你把任务写入 /etc/crontab 或用户 crontab 之前，先验证语法和执行时间。',
		useTitle: '如何使用这个 Cron 计划生成器',
		useBody:
			'输入一个五字段 cron 表达式，例如 5 4 * * *，或者使用 @daily、@weekly 等快捷方式。工具会把语法转换成自然语言，并计算下一次执行时间。',
		casesTitle: 'Linux Crontab 常见使用场景',
		cases: [
			'夜间备份和快照任务',
			'日志轮转与自动清理',
			'服务健康检查与告警脚本',
			'软件包更新提醒与维护任务',
		],
		faqTitle: 'Linux Cron 常见问题',
		faq: [
			{
				question: 'Linux 中的 cron 表达式是什么？',
				answer:
					'cron 表达式是 Linux 中 crontab 使用的五字段调度格式，用于自动执行命令。字段分别表示分钟、小时、每月日期、月份和星期几。',
			},
			{
				question: '在服务器上使用前，如何测试 crontab 计划？',
				answer:
					'可以使用 cron 计划生成器来解析表达式、查看自然语言说明，并确认下一次运行时间。这样能在写入 /etc/crontab 或用户 crontab 前减少常见错误。',
			},
			{
				question: 'cron 和 crontab 有什么区别？',
				answer:
					'cron 是 Linux 后台调度服务，负责执行定时任务；crontab 是定义这些任务与时间规则的表或文件格式。',
			},
		],
	},
};
const seo = supplementalCopy[locale];
const faqEntries = seo.faq;
const faqJsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqEntries.map((entry) => ({
		'@type': 'Question',
		name: entry.question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: entry.answer,
		},
	})),
});
---

<!doctype html>
<html lang={locale}>
	<head>
		<BaseHead title={t.metaTitle} description={t.metaDescription} />
		<script type="application/ld+json" set:html={faqJsonLd}></script>
	</head>
	<body>
		<Header />
		<main>
			<section class="surface-card hero scan-lines">
				<div class="terminal-pill">crontab -e</div>
				<h1>{t.title}</h1>
				<p class="lead">{t.lead}</p>
				<a class="back-link" href={toolsPath}>{t.backToTools}</a>
			</section>

			<section class="tool-grid">
				<article
					class="surface-card builder"
					id="cron-tool"
					data-copy-label={t.copy}
					data-copied-label={t.copied}
					data-invalid-label={t.invalid}
					data-no-run-label={t.noRun}
					data-at-label={t.at}
					data-default-description={t.defaultDescription}
				>
					<div class="section-label">{t.expression}</div>
					<div class="input-row">
						<input id="cron-expression" type="text" value="5 4 * * *" spellcheck="false" aria-label={t.expression} />
						<button id="copy-expression" type="button">{t.copy}</button>
					</div>
					<div class="preset-row" aria-label={t.shortcuts}>
						<button type="button" data-preset="5 4 * * *">{t.openExample}</button>
						<button type="button" data-preset="@hourly">@hourly</button>
						<button type="button" data-preset="@daily">@daily</button>
						<button type="button" data-preset="*/15 * * * *">*/15</button>
						<button type="button" data-preset="0 0 * * 0">0 0 * * 0</button>
					</div>

					<div class="result-grid">
						<div>
							<div class="section-label">{t.humanReadable}</div>
							<p id="cron-description" class="result-text">At 04:05.</p>
						</div>
						<div>
							<div class="section-label">{t.nextRun}</div>
							<p id="next-run" class="result-text">at 2026-03-16 04:05:00</p>
						</div>
					</div>

					<pre><code id="cron-output">5 4 * * *</code></pre>
					<p id="cron-error" class="error-message" hidden></p>
				</article>

				<article class="surface-card reference">
					<h2>{t.legend}</h2>
					<div class="legend-grid">
						<div><strong>{t.minute}</strong><span>0-59</span></div>
						<div><strong>{t.hour}</strong><span>0-23</span></div>
						<div><strong>{t.dayOfMonth}</strong><span>1-31</span></div>
						<div><strong>{t.month}</strong><span>1-12</span></div>
						<div><strong>{t.dayOfWeek}</strong><span>0-7</span></div>
					</div>

					<table>
						<tbody>
							<tr><td>*</td><td>any value</td></tr>
							<tr><td>,</td><td>value list separator</td></tr>
							<tr><td>-</td><td>range of values</td></tr>
							<tr><td>/</td><td>step values</td></tr>
							<tr><td>@yearly</td><td>non-standard</td></tr>
							<tr><td>@annually</td><td>non-standard</td></tr>
							<tr><td>@monthly</td><td>non-standard</td></tr>
							<tr><td>@weekly</td><td>non-standard</td></tr>
							<tr><td>@daily</td><td>non-standard</td></tr>
							<tr><td>@hourly</td><td>non-standard</td></tr>
							<tr><td>@reboot</td><td>non-standard</td></tr>
						</tbody>
					</table>
				</article>
			</section>

			<section class="surface-card seo-copy">
				<h2>{seo.guideTitle}</h2>
				<p>{seo.guideIntro}</p>
				<h3>{seo.useTitle}</h3>
				<p>{seo.useBody}</p>
				<h3>{seo.casesTitle}</h3>
				<ul>
					{seo.cases.map((item) => <li>{item}</li>)}
				</ul>
			</section>

			<section class="surface-card faq-copy" aria-label="Cron FAQ">
				<h2>{seo.faqTitle}</h2>
				{
					faqEntries.map((entry) => (
						<article class="faq-item">
							<h3>{entry.question}</h3>
							<p>{entry.answer}</p>
						</article>
					))
				}
			</section>
		</main>
		<Footer />

		<script is:inline define:vars={{ toolPath }}>
			const root = document.getElementById('cron-tool');
			const input = document.getElementById('cron-expression');
			const output = document.getElementById('cron-output');
			const description = document.getElementById('cron-description');
			const nextRun = document.getElementById('next-run');
			const error = document.getElementById('cron-error');
			const copyButton = document.getElementById('copy-expression');
			const presetButtons = Array.from(document.querySelectorAll('[data-preset]'));

			const labels = {
				copy: root?.dataset.copyLabel || 'Copy',
				copied: root?.dataset.copiedLabel || 'Copied',
				invalid: root?.dataset.invalidLabel || 'Invalid cron expression.',
				noRun: root?.dataset.noRunLabel || 'No next run found.',
				at: root?.dataset.atLabel || 'at',
				defaultDescription: root?.dataset.defaultDescription || 'Runs on schedule',
			};

			const nicknameMap = {
				'@yearly': '0 0 1 1 *',
				'@annually': '0 0 1 1 *',
				'@monthly': '0 0 1 * *',
				'@weekly': '0 0 * * 0',
				'@daily': '0 0 * * *',
				'@hourly': '0 * * * *',
			};

			const nicknameDescriptions = {
				'@yearly': 'Once a year at 00:00 on January 1.',
				'@annually': 'Once a year at 00:00 on January 1.',
				'@monthly': 'Once a month at 00:00 on day 1.',
				'@weekly': 'Once a week at 00:00 on Sunday.',
				'@daily': 'Once a day at 00:00.',
				'@hourly': 'Once an hour at minute 00.',
				'@reboot': 'When the system boots.',
			};

			function pad(value) {
				return String(value).padStart(2, '0');
			}

			function formatDate(date) {
				return `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())} ${pad(date.getHours())}:${pad(date.getMinutes())}:00`;
			}

			function expandExpression(expression) {
				const value = expression.trim();
				if (value in nicknameMap) return nicknameMap[value];
				return value;
			}

			function buildField(field, min, max, normalize = (value) => value) {
				if (field === '*') return { any: true, values: new Set(Array.from({ length: max - min + 1 }, (_, index) => normalize(index + min))) };

				const values = new Set();
				for (const part of field.split(',')) {
					const [base, stepText] = part.split('/');
					const step = stepText ? Number.parseInt(stepText, 10) : 1;
					if (!Number.isInteger(step) || step < 1) throw new Error('Invalid step');

					let start;
					let end;
					if (base === '*') {
						start = min;
						end = max;
					} else if (base.includes('-')) {
						const [startText, endText] = base.split('-');
						start = Number.parseInt(startText, 10);
						end = Number.parseInt(endText, 10);
					} else {
						start = Number.parseInt(base, 10);
						end = start;
					}

					if (!Number.isInteger(start) || !Number.isInteger(end) || start > end) throw new Error('Invalid range');
					for (let value = start; value <= end; value += step) {
						const normalized = normalize(value);
						if (normalized < min || normalized > max) throw new Error('Value out of range');
						values.add(normalized);
					}
				}

				if (values.size === 0) throw new Error('Empty field');
				return { any: false, values };
			}

			function parseCron(expression) {
				const raw = expression.trim();
				if (raw === '@reboot') {
					return { reboot: true, raw };
				}

				const expanded = expandExpression(raw);
				const fields = expanded.split(/\s+/);
				if (fields.length !== 5) throw new Error('Wrong field count');

				return {
					reboot: false,
					raw,
					minute: buildField(fields[0], 0, 59),
					hour: buildField(fields[1], 0, 23),
					dayOfMonth: buildField(fields[2], 1, 31),
					month: buildField(fields[3], 1, 12),
					dayOfWeek: buildField(fields[4], 0, 6, (value) => (value === 7 ? 0 : value)),
				};
			}

			function matchesDate(schedule, date) {
				if (schedule.reboot) return false;
				const minuteMatch = schedule.minute.values.has(date.getMinutes());
				const hourMatch = schedule.hour.values.has(date.getHours());
				const monthMatch = schedule.month.values.has(date.getMonth() + 1);
				const dayOfMonthMatch = schedule.dayOfMonth.values.has(date.getDate());
				const dayOfWeekMatch = schedule.dayOfWeek.values.has(date.getDay());

				if (!minuteMatch || !hourMatch || !monthMatch) return false;

				if (schedule.dayOfMonth.any && schedule.dayOfWeek.any) return true;
				if (schedule.dayOfMonth.any) return dayOfWeekMatch;
				if (schedule.dayOfWeek.any) return dayOfMonthMatch;
				return dayOfMonthMatch || dayOfWeekMatch;
			}

			function findNextRun(schedule) {
				if (schedule.reboot) return null;
				const candidate = new Date();
				candidate.setSeconds(0, 0);
				candidate.setMinutes(candidate.getMinutes() + 1);

				for (let index = 0; index < 60 * 24 * 366 * 2; index += 1) {
					if (matchesDate(schedule, candidate)) return new Date(candidate);
					candidate.setMinutes(candidate.getMinutes() + 1);
				}

				return null;
			}

			function humanize(expression, schedule) {
				if (expression in nicknameDescriptions) return nicknameDescriptions[expression];
				if (schedule.reboot) return nicknameDescriptions['@reboot'];

				const minuteValues = Array.from(schedule.minute.values).sort((a, b) => a - b);
				const hourValues = Array.from(schedule.hour.values).sort((a, b) => a - b);
				const raw = expandExpression(expression).split(/\s+/);
				const minuteField = raw[0];
				const hourField = raw[1];

				if (!schedule.dayOfMonth.any || !schedule.month.any || !schedule.dayOfWeek.any) {
					return `${labels.defaultDescription} ${expression}.`;
				}

				if (!schedule.minute.any && !schedule.hour.any && minuteValues.length === 1 && hourValues.length === 1) {
					return `At ${pad(hourValues[0])}:${pad(minuteValues[0])}.`;
				}

				if (minuteField.startsWith('*/') && schedule.hour.any) {
					return `Every ${minuteField.slice(2)} minutes.`;
				}

				if (!schedule.minute.any && schedule.hour.any && minuteValues.length === 1) {
					return `At minute ${pad(minuteValues[0])} past every hour.`;
				}

				if (schedule.minute.any && !schedule.hour.any && hourValues.length === 1) {
					return `Every minute during the ${pad(hourValues[0])}:00 hour.`;
				}

				return `${labels.defaultDescription} ${expression}.`;
			}

			async function copyExpression() {
				if (!input || !copyButton) return;
				await navigator.clipboard.writeText(input.value.trim());
				copyButton.textContent = labels.copied;
				window.setTimeout(() => {
					copyButton.textContent = labels.copy;
				}, 1200);
			}

			function render() {
				if (!input || !output || !description || !nextRun || !error) return;
				const expression = input.value.trim();
				output.textContent = expression;

				try {
					const schedule = parseCron(expression);
					description.textContent = humanize(expression, schedule);
					const next = findNextRun(schedule);
					nextRun.textContent = next ? `${labels.at} ${formatDate(next)}` : labels.noRun;
					error.hidden = true;
					error.textContent = '';
				} catch {
					description.textContent = labels.invalid;
					nextRun.textContent = labels.noRun;
					error.hidden = false;
					error.textContent = labels.invalid;
				}
			}

			input?.addEventListener('input', render);
			copyButton?.addEventListener('click', copyExpression);
			presetButtons.forEach((button) => {
				button.addEventListener('click', () => {
					const preset = button.getAttribute('data-preset');
					if (!preset || !input) return;
					input.value = preset;
					render();
				});
			});

			render();
		</script>
	</body>
</html>

<style>
	.hero {
		padding: clamp(1.2rem, 4vw, 2.2rem);
	}
	.lead {
		max-width: 68ch;
		font-size: clamp(1rem, 2.5vw, 1.15rem);
	}
	.back-link {
		display: inline-flex;
		margin-top: 1rem;
		text-decoration: none;
		font-weight: 700;
	}
	.tool-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.7fr) minmax(280px, 0.95fr);
		gap: 1rem;
		margin-top: 1rem;
	}
	.builder,
	.reference {
		padding: 1.2rem;
	}
	.section-label {
		margin-bottom: 0.45rem;
		color: var(--date-muted);
		font-size: 0.82rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}
	.input-row {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 0.75rem;
	}
	.input-row input {
		width: 100%;
		padding: 0.85rem 1rem;
		border-radius: 0.95rem;
		border: 1px solid var(--hero-recent-border);
		background: var(--surface-soft);
		color: var(--foreground);
		font: inherit;
	}
	.input-row button,
	.preset-row button {
		padding: 0.75rem 0.95rem;
		border-radius: 999px;
		border: 1px solid var(--border);
		background: var(--surface-soft);
		color: var(--foreground);
		font: inherit;
		font-weight: 700;
		cursor: pointer;
	}
	.preset-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		margin: 0.9rem 0 1rem;
	}
	.result-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		margin-bottom: 1rem;
	}
	.result-text {
		margin: 0;
		font-size: 1.02rem;
		font-weight: 700;
		color: var(--title-strong);
	}
	.error-message {
		color: #ff9c88;
		margin-top: 0.75rem;
	}
	.legend-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.8rem;
		margin: 1rem 0 1.1rem;
	}
	.legend-grid div {
		display: grid;
		gap: 0.18rem;
		padding: 0.8rem 0.9rem;
		border-radius: 0.9rem;
		border: 1px solid var(--hero-recent-border);
		background: var(--surface-soft);
	}
	table {
		width: 100%;
		border-collapse: collapse;
	}
	td {
		padding: 0.55rem 0;
		border-bottom: 1px solid var(--hero-recent-border);
		vertical-align: top;
	}
	td:first-child {
		width: 7rem;
		font-family: 'JetBrains Mono', monospace;
		font-weight: 700;
	}
	.seo-copy {
		margin-top: 1rem;
		padding: clamp(1.1rem, 3.4vw, 1.6rem);
	}
	.seo-copy h2,
	.seo-copy h3 {
		margin-bottom: 0.45rem;
	}
	.seo-copy p {
		margin: 0.35rem 0 0.95rem;
		max-width: 80ch;
	}
	.seo-copy ul {
		margin: 0.5rem 0 0;
		padding-left: 1.2rem;
	}
	.seo-copy li {
		margin-bottom: 0.35rem;
	}
	.faq-copy {
		margin-top: 1rem;
		padding: clamp(1.1rem, 3.4vw, 1.6rem);
	}
	.faq-item + .faq-item {
		margin-top: 1rem;
		padding-top: 1rem;
		border-top: 1px solid var(--hero-recent-border);
	}
	.faq-item h3 {
		margin: 0 0 0.4rem;
	}
	.faq-item p {
		margin: 0;
		max-width: 80ch;
	}
	@media (max-width: 900px) {
		.tool-grid {
			grid-template-columns: 1fr;
		}
	}
	@media (max-width: 640px) {
		.input-row,
		.result-grid,
		.legend-grid {
			grid-template-columns: 1fr;
		}
	}
</style>